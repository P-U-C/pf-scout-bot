# ============================================================
# pf-scout-bot — environment configuration
# Copy to .env and fill in your values
# ============================================================

# === Phase 1: Scout API ===
PF_SCOUT_HOST=127.0.0.1
PF_SCOUT_PORT=8420
PF_SCOUT_PF_JWT_TOKEN=your-postfiat-jwt-token
PF_SCOUT_GITHUB_TOKEN=your-github-token
PF_SCOUT_LOG_LEVEL=info

# === Phase 2: Bot ===

# XRPL wallet seed for the bot (starts with 'sEd')
# Generate: npx xrpl-keygen  OR  pft-chatbot-mcp wallet create
BOT_SEED=sEdYourBotSeedHere

# XRPL WebSocket server
XRPL_SERVER=wss://xrplcluster.com

# How often to poll for new messages (milliseconds)
POLL_INTERVAL_MS=60000

# Scout API base URL (should match PF_SCOUT_HOST:PF_SCOUT_PORT above)
SCOUT_API_URL=http://127.0.0.1:8420

# Bot identity (shown in the Task Node Agent Directory)
BOT_NAME=PF Scout
BOT_DESCRIPTION=Contributor discovery and recruitment intelligence for the Post Fiat ecosystem

# LLM for response formatting (optional — falls back to templates if unset)
# Anthropic (preferred):
ANTHROPIC_API_KEY=
# OpenAI (fallback):
OPENAI_API_KEY=
# Model to use (Claude model if using Anthropic, GPT model if using OpenAI):
LLM_MODEL=claude-3-haiku-20240307

# === Phase 3: Enrichment ===
PF_SESSION_COOKIE=
PF_JWT_TOKEN=
GITHUB_TOKEN=
REFRESH_INTERVAL_HOURS=6
EXTERNAL_SCOUT_ORGS=cosmos,ethereum,solana-labs,ripple,hyperledger
MAX_EXTERNAL_PER_ORG=20
SCOUT_RUBRIC=b1e55ed
